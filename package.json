{
  "name": "love-training",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "backend",
    "llm-gateway",
    "frontend",
    "shared"
  ],
  "scripts": {
    "dev:llm": "npm --workspace llm-gateway run dev",
